<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{width:100%;overflow-x:hidden}
:root{--cream:#FFF8F0;--peach:#FFE4CC;--pink:#C97B7B;--pink-light:#E8A89A;--pink-pale:#FFD6E8;--teal:#5B9B8E;--text-dark:#3D2B1F;--text-mid:#6B4E3D;--text-light:#A08070;--green:#6BCB77;--blue:#4D96FF;}
body{font-family:'Noto Sans KR',sans-serif;background:var(--cream);color:var(--text-dark);min-height:100vh}
.bingo-header{background:linear-gradient(135deg,#D4E8D0 0%,#D6E4FF 100%);padding:2.5rem 1.2rem 1.2rem;text-align:center;position:relative}
.bingo-back{position:absolute;left:.9rem;top:.9rem;background:rgba(255,255,255,.65);border:1px solid rgba(200,160,140,.3);border-radius:20px;padding:6px 14px;font-size:12px;color:var(--text-mid);cursor:pointer;font-family:'Noto Sans KR',sans-serif;min-height:36px;text-decoration:none;display:inline-flex;align-items:center}
.bingo-title{font-family:'Noto Serif KR',serif;font-size:1.4rem;color:var(--text-dark);margin-bottom:.2rem}
.bingo-sub{font-size:11px;color:var(--text-light)}
.screen{display:none;padding:1.5rem 1rem;max-width:440px;margin:0 auto}
.screen.active{display:block}
.card{background:#fff;border-radius:22px;padding:1.8rem 1.5rem;border:1.5px solid rgba(200,160,140,.15);margin-bottom:1rem}
.card-emoji{font-size:44px;margin-bottom:.8rem;display:block;text-align:center}
.card-title{font-family:'Noto Serif KR',serif;font-size:18px;color:var(--text-dark);margin-bottom:.3rem;text-align:center}
.card-sub{font-size:12px;color:var(--text-light);margin-bottom:1.2rem;line-height:1.8;text-align:center}
.field{width:100%;border:1.5px solid rgba(200,160,140,.25);border-radius:12px;padding:12px 14px;font-family:'Noto Sans KR',sans-serif;font-size:15px;color:var(--text-dark);background:var(--cream);outline:none;text-align:center;margin-bottom:.8rem;-webkit-appearance:none}
.field:focus{border-color:rgba(107,203,119,.5)}
.field.code{letter-spacing:6px;font-size:20px;font-weight:700;text-transform:uppercase}
.btn{width:100%;border:none;border-radius:12px;padding:13px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:500;cursor:pointer;min-height:48px;margin-bottom:.6rem}
.btn:active{transform:scale(.98)}
.btn-green{background:linear-gradient(135deg,#6BCB77,#4D96FF);color:#fff}
.btn-pink{background:linear-gradient(135deg,var(--pink),var(--pink-light));color:#fff}
.btn-outline{background:#fff;border:1.5px solid rgba(200,160,140,.3)!important;color:var(--text-mid)}
.divider{text-align:center;font-size:12px;color:var(--text-light);margin:.4rem 0 1rem;position:relative}
.divider::before,.divider::after{content:'';position:absolute;top:50%;width:40%;height:1px;background:rgba(200,160,140,.2)}
.divider::before{left:0}.divider::after{right:0}
.room-code-display{background:linear-gradient(135deg,#F0FFF0,#F0F8FF);border-radius:16px;padding:1.2rem;text-align:center;margin-bottom:1rem;border:1.5px solid rgba(107,203,119,.3)}
.room-code-label{font-size:10px;letter-spacing:2px;color:var(--teal);margin-bottom:.4rem;text-transform:uppercase}
.room-code-val{font-family:'Noto Serif KR',serif;font-size:32px;font-weight:600;color:var(--text-dark);letter-spacing:8px}
.room-code-hint{font-size:11px;color:var(--text-light);margin-top:.4rem}
.waiting-players{background:#fff;border-radius:16px;padding:1rem;border:1.5px solid rgba(200,160,140,.15);margin-bottom:1rem}
.waiting-label{font-size:10px;letter-spacing:2px;color:var(--text-light);margin-bottom:.8rem;text-transform:uppercase}
.waiting-list{display:flex;flex-direction:column;gap:6px}
.waiting-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;background:var(--cream);font-size:13px}
.waiting-item.me{background:linear-gradient(135deg,#F0FFF0,#F0F8FF);border:1px solid rgba(107,203,119,.3)}
.waiting-dot{width:8px;height:8px;border-radius:50%;background:#6BCB77;flex-shrink:0}
.waiting-name{flex:1;font-weight:500}
.waiting-host{font-size:10px;color:var(--teal);font-weight:600}
.waiting-count{font-size:12px;color:var(--text-light);text-align:center;margin-bottom:.8rem}
.now-playing{background:linear-gradient(135deg,#F0FFF0,#F0F8FF);border-radius:18px;padding:1.2rem;margin-bottom:1rem;border:1.5px solid rgba(107,203,119,.3);text-align:center}
.now-playing-label{font-size:10px;letter-spacing:2px;color:var(--teal);margin-bottom:.5rem;text-transform:uppercase}
.now-playing-title{font-family:'Noto Serif KR',serif;font-size:18px;color:var(--text-dark);margin-bottom:.8rem;min-height:28px}
.now-playing-progress{height:6px;background:rgba(107,203,119,.2);border-radius:3px;overflow:hidden;margin-bottom:.5rem}
.now-playing-fill{height:100%;background:linear-gradient(90deg,#6BCB77,#4D96FF);border-radius:3px;width:0%;transition:width .5s linear}
.now-playing-timer{font-size:11px;color:var(--text-light);display:flex;justify-content:space-between}
.now-playing-status{font-size:13px;color:var(--teal);font-weight:500;margin-top:.5rem;min-height:20px}
.bingo-board-label{font-size:10px;letter-spacing:2px;color:var(--text-light);margin-bottom:.8rem;text-transform:uppercase;text-align:center}
.bingo-board{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1rem}
.bingo-cell{aspect-ratio:1;border-radius:14px;border:2px solid rgba(200,160,140,.2);background:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-size:11px;font-weight:500;color:var(--text-dark);text-align:center;padding:6px;line-height:1.4;transition:all .2s;position:relative;overflow:hidden;word-break:keep-all}
.bingo-cell:active{transform:scale(.95)}
.bingo-cell.checked{background:linear-gradient(135deg,#D4E8D0,#D6E4FF);border-color:#6BCB77;color:#2d7a3a}
.bingo-cell.checked::after{content:'✓';position:absolute;top:4px;right:6px;font-size:12px;color:#6BCB77;font-weight:700}
.bingo-cell.bingo-line{background:linear-gradient(135deg,#FFD700,#FFA500);border-color:#FFD700;color:#7a4a00}
.bingo-cell.shake{animation:shake .3s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
.bingo-counter{display:flex;gap:8px;justify-content:center;margin-bottom:1rem}
.bingo-badge{background:linear-gradient(135deg,#FFD700,#FFA500);color:#7a4a00;border-radius:20px;padding:5px 14px;font-size:12px;font-weight:700}
.bingo-shout-btn{width:100%;background:linear-gradient(135deg,#FFD700,#FFA500);color:#7a4a00;border:none;border-radius:14px;padding:15px;font-family:'Noto Serif KR',serif;font-size:18px;font-weight:600;cursor:pointer;min-height:52px;display:none;animation:pulse 1s infinite;margin-bottom:1rem}
.bingo-shout-btn.show{display:block}
.bingo-shout-btn:active{transform:scale(.97)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.75}}
.players-box{background:#fff;border-radius:18px;padding:1rem;border:1.5px solid rgba(200,160,140,.15);margin-bottom:1rem}
.players-label{font-size:10px;letter-spacing:2px;color:var(--text-light);margin-bottom:.8rem;text-transform:uppercase}
.player-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;background:var(--cream);font-size:13px;margin-bottom:6px}
.player-item.me{background:linear-gradient(135deg,#F0FFF0,#F0F8FF);border:1px solid rgba(107,203,119,.3)}
.player-name{flex:1;font-weight:500}
.player-score{font-size:11px;color:var(--teal);font-weight:700}
.player-finished{font-size:11px;color:#DAA520;font-weight:700}
.toast-wrap{position:fixed;top:1rem;left:50%;transform:translateX(-50%);z-index:999;display:flex;flex-direction:column;gap:8px;pointer-events:none;width:min(320px,90vw)}
.toast{background:rgba(30,20,10,.88);color:#fff;border-radius:14px;padding:10px 16px;font-size:13px;font-family:'Noto Sans KR',sans-serif;backdrop-filter:blur(8px);animation:toastIn .3s ease;text-align:center}
@keyframes toastIn{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
.toast.out{animation:toastOut .3s ease forwards}
@keyframes toastOut{to{opacity:0;transform:translateY(-10px)}}
#finish-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(20,10,5,.85);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:1rem}
#finish-overlay.show{display:flex}
.finish-box{background:#fff;border-radius:24px;padding:2rem;text-align:center;max-width:300px;width:100%}
.finish-emoji{font-size:56px;margin-bottom:1rem}
.finish-title{font-family:'Noto Serif KR',serif;font-size:22px;color:var(--text-dark);margin-bottom:.4rem}
.finish-sub{font-size:13px;color:var(--text-light);margin-bottom:1.4rem}
.finish-close{background:linear-gradient(135deg,#6BCB77,#4D96FF);color:#fff;border:none;border-radius:12px;padding:12px 28px;font-family:'Noto Sans KR',sans-serif;font-size:14px;font-weight:500;cursor:pointer}
.end-ranking-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(200,160,140,.1)}
.rank-num{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--peach),var(--pink-pale));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--pink);flex-shrink:0}
.rank-num.gold{background:linear-gradient(135deg,#FFD700,#FFA500);color:#fff}
.rank-num.silver{background:linear-gradient(135deg,#C0C0C0,#A0A0A0);color:#fff}
.rank-num.bronze{background:linear-gradient(135deg,#CD7F32,#A0522D);color:#fff}
</style>
</head>
<body>
<div class="bingo-header">
  <a class="bingo-back" href="index.html">← 돌아가기</a>
  <div class="bingo-title">🎲 음악 빙고</div>
  <div class="bingo-sub">친구들과 함께 빙고를 완성해요!</div>
</div>
<div class="toast-wrap" id="toast-wrap"></div>

<!-- 1. 닉네임 -->
<div class="screen active" id="screen-nickname">
  <div style="height:.5rem"></div>
  <div class="card">
    <span class="card-emoji">🎵</span>
    <div class="card-title">음악 빙고</div>
    <div class="card-sub">노래가 나오면 빙고판에서<br>제목을 찾아 눌러요!</div>
    <input class="field" id="nickname-input" type="text" placeholder="이름을 입력해요 (예: 지민)" maxlength="10" onkeydown="if(event.key==='Enter')goToRoom()">
    <button class="btn btn-green" onclick="goToRoom()">다음 →</button>
  </div>
</div>

<!-- 2. 방 선택 -->
<div class="screen" id="screen-room">
  <div class="card">
    <span class="card-emoji">🏠</span>
    <div class="card-title">방 선택</div>
    <div class="card-sub">새 방을 만들거나<br>친구 방에 들어가요!</div>
    <button class="btn btn-green" onclick="createRoom()">🎮 새 방 만들기</button>
    <div class="divider">또는</div>
    <input class="field code" id="room-code-input" type="text" placeholder="방 코드 입력" maxlength="4" onkeydown="if(event.key==='Enter')joinRoom()">
    <button class="btn btn-outline" onclick="joinRoom()">🚪 방 입장하기</button>
  </div>
</div>

<!-- 3. 대기실 -->
<div class="screen" id="screen-waiting">
  <div class="room-code-display">
    <div class="room-code-label">방 코드</div>
    <div class="room-code-val" id="room-code-val">----</div>
    <div class="room-code-hint">친구들에게 이 코드를 알려줘요!</div>
  </div>
  <div class="waiting-players">
    <div class="waiting-label">👥 참여자</div>
    <div class="waiting-count" id="waiting-count">0명 참여 중</div>
    <div class="waiting-list" id="waiting-list"></div>
  </div>
  <button class="btn btn-green" id="start-btn" onclick="startGame()" style="display:none">🎵 게임 시작!</button>
  <div id="waiting-msg" style="text-align:center;font-size:13px;color:var(--text-light);padding:.5rem">방장이 게임을 시작할 때까지 기다려요...</div>
</div>

<!-- 4. 게임 -->
<div class="screen" id="screen-game">
  <div class="now-playing">
    <div class="now-playing-label">🎵 지금 재생 중</div>
    <div class="now-playing-title" id="now-playing-title">잠깐만요...</div>
    <div class="now-playing-progress">
      <div class="now-playing-fill" id="now-playing-fill"></div>
    </div>
    <div class="now-playing-timer">
      <span id="timer-cur">0초</span>
      <span id="timer-total">30초</span>
    </div>
    <div class="now-playing-status" id="now-playing-status">노래를 잘 들어봐요 🎧</div>
  </div>
  <div class="bingo-board-label">🎲 나의 빙고판</div>
  <div class="bingo-board" id="bingo-board"></div>
  <div class="bingo-counter" id="bingo-counter"></div>
  <button class="bingo-shout-btn" id="bingo-shout-btn" onclick="shoutBingo()">🎉 빙고!</button>
  <div class="players-box">
    <div class="players-label">👥 참여자 현황</div>
    <div id="players-list"></div>
  </div>
</div>

<!-- 5. 종료 -->
<div class="screen" id="screen-end">
  <div class="card" style="text-align:center">
    <span class="card-emoji">🏆</span>
    <div class="card-title">게임 종료!</div>
    <div class="card-sub">모든 노래가 재생됐어요!</div>
    <div id="end-ranking" style="text-align:left;margin-bottom:1.2rem"></div>
    <button class="btn btn-pink" onclick="location.reload()">🔄 다시 하기</button>
    <button class="btn btn-outline" onclick="location.href='index.html'">홈으로</button>
  </div>
</div>

<!-- 빙고 완성 오버레이 -->
<div id="finish-overlay">
  <div class="finish-box">
    <div class="finish-emoji" id="finish-emoji">🎉</div>
    <div class="finish-title" id="finish-title">빙고!</div>
    <div class="finish-sub" id="finish-sub">빙고를 완성했어요!</div>
    <button class="finish-close" onclick="closeFinish()">계속 하기</button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const SUPABASE_URL='https://aoywuhpqivpczstoogcm.supabase.co';
const SUPABASE_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFveXd1aHBxaXZwY3pzdG9vZ2NtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkzNzc4MDQsImV4cCI6MjA5NDk1MzgwNH0.UgxYDvQpTZA_g2wuvwh6QyS4cogKnCkG3FjG9IRd_Cw';
const sb=supabase.createClient(SUPABASE_URL,SUPABASE_KEY);
const SONGS=[
  {name:'문어의 꿈',file:'audio/octopus.mp3'},
  {name:'신호등',file:'audio/signal.mp3'},
  {name:'반짝반짝 작은별',file:'audio/twinkle.mp3'},
  {name:'곰세마리',file:'audio/threebears.mp3'},
  {name:'상어가족',file:'audio/babyshark.mp3'},
  {name:'캐치티니핑',file:'audio/tiniping.mp3'},
  {name:'타요타요',file:'audio/tayo.mp3'},
  {name:'뽀로로',file:'audio/pororo.mp3'},
  {name:'생일축하합니다',file:'audio/birthday.mp3'},
  {name:'올챙이와 개구리',file:'audio/tadpole.mp3'},
  {name:'멋쟁이토마토',file:'audio/tomato.mp3'},
];
const PLAY_SECONDS=30;
let myNickname='',myPlayerId=null,myGameId=null,myRoomCode='',isHost=false;
let myBoard=[],myChecked=[],myBingoCount=0,shoutedBingo=false;
let gameAudio=null,timerInterval=null,elapsed=0,gameEnded=false;
let notifiedPlayers=new Set(),notifiedFinished=new Set();
let songOrder=[],currentSongIdx=0,syncInterval=null;

function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById('screen-'+id).classList.add('active');}

function toast(msg,dur=3000){
  const wrap=document.getElementById('toast-wrap');
  const el=document.createElement('div');
  el.className='toast';el.textContent=msg;wrap.appendChild(el);
  if(navigator.vibrate)navigator.vibrate([80,40,80]);
  setTimeout(()=>{el.classList.add('out');setTimeout(()=>el.remove(),300);},dur);
}

function genCode(){return Math.random().toString(36).substring(2,6).toUpperCase();}
function makeBoard(){return [...SONGS].sort(()=>Math.random()-.5).slice(0,9).map(s=>s.name);}

function goToRoom(){
  const nick=document.getElementById('nickname-input').value.trim();
  if(!nick){alert('이름을 입력해줘요!');return;}
  myNickname=nick;showScreen('room');
}

async function createRoom(){
  const code=genCode();
  const songOrd=[...SONGS].sort(()=>Math.random()-.5).map(s=>s.name);
  const{data:game,error:ge}=await sb.from('bingo_games').insert([{room_code:code,status:'waiting',song_order:songOrd}]).select().single();
  if(ge){alert('방 만들기 실패: '+ge.message);return;}
  myGameId=game.id;myRoomCode=code;isHost=true;
  await joinAsPlayer(game.id);
  await sb.from('bingo_games').update({host_id:myPlayerId}).eq('id',game.id);
  document.getElementById('room-code-val').textContent=code;
  document.getElementById('start-btn').style.display='block';
  document.getElementById('waiting-msg').style.display='none';
  showScreen('waiting');subscribeWaiting();loadWaitingPlayers();
}

async function joinRoom(){
  const code=document.getElementById('room-code-input').value.trim().toUpperCase();
  if(code.length!==4){alert('방 코드는 4자리예요!');return;}
  const{data:game,error}=await sb.from('bingo_games').select('*').eq('room_code',code).single();
  if(error||!game){alert('방을 찾을 수 없어요 😢');return;}
  if(game.status==='playing'){alert('이미 게임이 시작됐어요!');return;}
  myGameId=game.id;myRoomCode=code;isHost=false;
  await joinAsPlayer(game.id);
  document.getElementById('room-code-val').textContent=code;
  document.getElementById('start-btn').style.display='none';
  document.getElementById('waiting-msg').style.display='block';
  showScreen('waiting');subscribeWaiting();loadWaitingPlayers();
}

async function joinAsPlayer(gameId){
  const board=makeBoard();myBoard=board;
  const{data,error}=await sb.from('bingo_players').insert([{game_id:gameId,nickname:myNickname,board:board,checked:[],bingo_count:0,finished:false}]).select().single();
  if(error){alert('참가 실패: '+error.message);return;}
  myPlayerId=data.id;
}

function subscribeWaiting(){
  sb.channel('waiting-'+myGameId)
    .on('postgres_changes',{event:'*',schema:'public',table:'bingo_players',filter:`game_id=eq.${myGameId}`},()=>{loadWaitingPlayers();})
    .on('postgres_changes',{event:'UPDATE',schema:'public',table:'bingo_games',filter:`id=eq.${myGameId}`},(payload)=>{
      if(payload.new.status==='playing'){songOrder=payload.new.song_order;enterGame();}
    })
    .subscribe();
}

async function loadWaitingPlayers(){
  const{data}=await sb.from('bingo_players').select('*').eq('game_id',myGameId).order('created_at',{ascending:true});
  if(!data)return;
  document.getElementById('waiting-list').innerHTML=data.map(p=>`
    <div class="waiting-item${p.id===myPlayerId?' me':''}">
      <div class="waiting-dot"></div>
      <span class="waiting-name">${p.nickname}${p.id===myPlayerId?' (나)':''}</span>
      ${p.id===myPlayerId&&isHost?'<span class="waiting-host">방장</span>':''}
    </div>`).join('');
  document.getElementById('waiting-count').textContent=data.length+'명 참여 중';
  data.forEach(p=>{
    if(p.id!==myPlayerId&&!notifiedPlayers.has(p.id)){
      notifiedPlayers.add(p.id);
      toast('🙋 '+p.nickname+'님이 입장했어요!');
    }
  });
}

async function startGame(){
  const{data:game}=await sb.from('bingo_games').select('song_order').eq('id',myGameId).single();
  songOrder=game.song_order;
  await sb.from('bingo_games').update({status:'playing',started_at:new Date().toISOString()}).eq('id',myGameId);
  enterGame();
}

function enterGame(){
  showScreen('game');renderBoard();currentSongIdx=0;playSong(0);subscribeGame();
}

function renderBoard(){
  const el=document.getElementById('bingo-board');
  const lines=getBingoLines();const lineSet=new Set(lines.flat());
  el.innerHTML=myBoard.map((name,i)=>{
    const checked=myChecked.includes(i);const inLine=lineSet.has(i);
    let cls='bingo-cell';
    if(checked&&inLine)cls+=' bingo-line';else if(checked)cls+=' checked';
    return `<div class="${cls}" id="cell-${i}" onclick="checkCell(${i})">${name}</div>`;
  }).join('');
}

function checkCell(idx){
  if(gameEnded)return;
  const currentSong=songOrder[currentSongIdx];if(!currentSong)return;
  if(myBoard[idx]!==currentSong){
    const cell=document.getElementById('cell-'+idx);
    if(cell){cell.classList.add('shake');setTimeout(()=>cell.classList.remove('shake'),300);}
    return;
  }
  if(myChecked.includes(idx))return;
  myChecked=[...myChecked,idx];renderBoard();checkBingo();saveProgress();
}

async function saveProgress(){await sb.from('bingo_players').update({checked:myChecked,bingo_count:myBingoCount}).eq('id',myPlayerId);}

function getBingoLines(){
  const lines=[];
  for(let r=0;r<3;r++){const row=[r*3,r*3+1,r*3+2];if(row.every(i=>myChecked.includes(i)))lines.push(row);}
  for(let c=0;c<3;c++){const col=[c,c+3,c+6];if(col.every(i=>myChecked.includes(i)))lines.push(col);}
  if([0,4,8].every(i=>myChecked.includes(i)))lines.push([0,4,8]);
  if([2,4,6].every(i=>myChecked.includes(i)))lines.push([2,4,6]);
  return lines;
}

function checkBingo(){
  const lines=getBingoLines();
  if(lines.length>myBingoCount){myBingoCount=lines.length;renderBoard();updateBingoCounter();document.getElementById('bingo-shout-btn').classList.add('show');}
}

function updateBingoCounter(){
  const el=document.getElementById('bingo-counter');
  el.innerHTML=myBingoCount>0?`<span class="bingo-badge">🎉 ${myBingoCount}빙고!</span>`:'';
}

async function shoutBingo(){
  if(shoutedBingo)return;shoutedBingo=true;
  document.getElementById('bingo-shout-btn').classList.remove('show');
  await sb.from('bingo_players').update({finished:true,bingo_count:myBingoCount}).eq('id',myPlayerId);
  showFinish('나',myBingoCount);
}

function showFinish(name,count){
  document.getElementById('finish-emoji').textContent='🏆';
  document.getElementById('finish-title').textContent=name==='나'?'빙고 완성!':name+'님이 빙고!';
  document.getElementById('finish-sub').textContent=count+'줄 빙고를 완성했어요! 🎉';
  document.getElementById('finish-overlay').classList.add('show');
  if(navigator.vibrate)navigator.vibrate([100,50,100,50,200]);
}
function closeFinish(){document.getElementById('finish-overlay').classList.remove('show');}

function playSong(idx){
  if(idx>=songOrder.length){endGame();return;}
  currentSongIdx=idx;
  const songName=songOrder[idx];
  const songData=SONGS.find(s=>s.name===songName);
  document.getElementById('now-playing-title').textContent=songName;
  document.getElementById('now-playing-status').textContent='노래를 잘 들어봐요 🎧';
  document.getElementById('now-playing-fill').style.width='0%';
  document.getElementById('timer-cur').textContent='0초';
  document.getElementById('timer-total').textContent=PLAY_SECONDS+'초';
  if(gameAudio){gameAudio.pause();gameAudio.src='';}
  if(songData){gameAudio=new Audio(songData.file);gameAudio.play().catch(()=>{});}
  elapsed=0;if(timerInterval)clearInterval(timerInterval);
  timerInterval=setInterval(()=>{
    elapsed++;
    document.getElementById('now-playing-fill').style.width=Math.min((elapsed/PLAY_SECONDS)*100,100)+'%';
    document.getElementById('timer-cur').textContent=elapsed+'초';
    if(elapsed>=PLAY_SECONDS){
      clearInterval(timerInterval);if(gameAudio)gameAudio.pause();
      document.getElementById('now-playing-status').textContent='다음 노래로 넘어가요! ⏭';
      setTimeout(()=>playSong(idx+1),1500);
    }
  },1000);
}

function endGame(){
  gameEnded=true;if(gameAudio)gameAudio.pause();if(timerInterval)clearInterval(timerInterval);if(syncInterval)clearInterval(syncInterval);
  document.getElementById('now-playing-title').textContent='게임 종료!';
  document.getElementById('now-playing-status').textContent='모든 노래가 끝났어요 🎵';
  setTimeout(showEndScreen,1500);
}

async function showEndScreen(){
  showScreen('end');
  const{data}=await sb.from('bingo_players').select('*').eq('game_id',myGameId).order('bingo_count',{ascending:false}).order('created_at',{ascending:true});
  const medals=['gold','silver','bronze'];
  document.getElementById('end-ranking').innerHTML=data?data.map((p,i)=>`
    <div class="end-ranking-item">
      <div class="rank-num ${medals[i]||''}">${i+1}</div>
      <div style="flex:1;font-size:13px;font-weight:500">${p.nickname}${p.id===myPlayerId?' (나)':''}</div>
      <div style="font-size:13px;font-weight:700;color:var(--teal)">${p.bingo_count}빙고 ${p.finished?'🏆':''}</div>
    </div>`).join(''):'';
}

function subscribeGame(){
  sb.channel('game-'+myGameId)
    .on('postgres_changes',{event:'UPDATE',schema:'public',table:'bingo_players',filter:`game_id=eq.${myGameId}`},()=>{loadGamePlayers();})
    .subscribe();
  loadGamePlayers();syncInterval=setInterval(loadGamePlayers,5000);
}

async function loadGamePlayers(){
  const{data}=await sb.from('bingo_players').select('*').eq('game_id',myGameId).order('created_at',{ascending:true});
  if(!data)return;
  document.getElementById('players-list').innerHTML=data.map(p=>`
    <div class="player-item${p.id===myPlayerId?' me':''}">
      <span class="player-name">${p.nickname}${p.id===myPlayerId?' (나)':''}</span>
      ${p.finished?`<span class="player-finished">🏆 ${p.bingo_count}빙고!</span>`:`<span class="player-score">${p.bingo_count>0?p.bingo_count+'빙고':''}</span>`}
    </div>`).join('');
  data.forEach(p=>{
    if(p.id!==myPlayerId&&p.finished&&!notifiedFinished.has(p.id)){
      notifiedFinished.add(p.id);
      toast('🏆 '+p.nickname+'님이 빙고를 완성했어요!',4000);
      if(!document.getElementById('finish-overlay').classList.contains('show')){showFinish(p.nickname,p.bingo_count);}
    }
  });
}
</script>
</body>
</html>
